{
  "rootDir": "src",
  "testRegex": ".*\\.test\\.ts$",
  "preset": "ts-jest",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@config/(.*)$": "<rootDir>/base/config/$1",
    "^@domain/(.*)$": "<rootDir>/domain/$1",
    "^@shared/(.*)$": "<rootDir>/shared/$1",
    "^@templating/(.*)$": "<rootDir>/base/templating/$1"
  }
}
