  - id: hypercorp
    name:
      pl: Hiperkorporacja
      en: hypercorporation
    items:
      - id: cognite
        name:
          pl: Cognite
          en: Cognite
      - id: direct-action
        name:
          pl: Direct Action
          en: Direct Action
      - id: ecologene
        name:
          pl: Ecologene
          en: Ecologene
      - id: fajing
        name:
          pl: Fa Jing
          en: Fa Jing
      - id: jaehon-offworld
        name:
          pl: Jaehon Offworld
          en: Jaehon Offworld
      - id: terragenesis
        name:
          pl: Terragenesis
          en: Terragenesis
      - id: comet-express
        name:
          pl: Comet Express
          en: Comet Express
        description:
          pl: |
            Comet Express to hiperkorporacja specjalizująca się w transporcie kosmicznym i logistyce. 
            Firma oferuje szeroki zakres usług, od przewozu ładunków po transport pasażerski, 
            obsługując zarówno klientów indywidualnych, jak i korporacyjnych.
          en: |
            Comet Express is a hypercorporation specializing in space transportation and logistics. 
            The company offers a wide range of services, from cargo transport to passenger transport, 
            serving both individual and corporate clients.
        url:
          pl: https://forseti.pl/pages/pl/eclipse-phase_encyklopedia_hiperkorpy_ep-comet-express.html
        relations:
          allies:
            - hypercorp
          adversaries:
            - polity:jovian-republic
          bases:
            - location:luna:surface:nectar
            - location:mars:surface:olympus
            - location:mars:trojans:transix
          interests:
            - services:logistics
      - id: exotech
        name:
          pl: Exotech
          en: Exotech
      - id: experia
        name:
          pl: Experia
          en: Experia
      - id: gatekeeper
        name:
          pl: Gatekeeper
          en: Gatekeeper
      - id: go-nin
        name:
          pl: Go-nin
          en: Go-nin
      - id: gorgon-defense-systems
        name:
          pl: Gorgon Defense Systems
          en: Gorgon Defense Systems
        description:
          pl: |
            Gorgon Defense Systems to hiperkorporacja specjalizująca się w produkcji zaawansowanych 
            systemów obronnych i broni dla klientów wojskowych i paramilitarnych.
          en: |
            Gorgon Defense Systems is a hypercorporation specializing in the production of advanced 
            defense systems and weapons for military and paramilitary clients.
        url:

      - id: nimbus
        name:
          pl: Nimbus
          en: Nimbus
      - id: omnicor
