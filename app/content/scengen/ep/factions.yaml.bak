      - id: lunar-lagrange-alliance
        name:
          pl: Sojusz Księżycowo-Lagrange'owski
          en: Lunar-Lagrange Alliance
      - id: planetary-consortium
        name:
          pl: Konsorcjum Planetarne
          en: Planetary Consortium
