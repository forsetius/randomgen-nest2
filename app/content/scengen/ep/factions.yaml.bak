          owns:
            - location:mars
          adversaries:
            - polity:morningstar-constellation
            - polity:titanian-commonwealth
            - polity:tharsis-league
            - polity:jovian-republic
            - polity:anarchists
      - id: titanian-commonwealth
        name:
          pl: Wspólnota Tytana
          en: Titanian Commonwealth
        relations:
          owns:
            - location:saturn:titan
          adversaries:
