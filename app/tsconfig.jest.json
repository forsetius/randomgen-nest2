{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node", "jest"],
    "noEmit": true,
    "sourceMap": true
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*.ts", "test/**/*.ts", "test/**/*.json"],
  "ts-node": {
    "project": "./tsconfig.jest.json",
    "transpileOnly": true,
    "files": true,
    "pretty": true,
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "Node"
    }
  }
}
