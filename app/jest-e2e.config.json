{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "test/e2e",
  "testRegex": ".*\\.e2e-test\\.ts$",
  "setupFiles": ["<rootDir>/setEnvVars.ts"],
  "moduleNameMapper": {
    "^@config/(.*)$": "<rootDir>/../../src/base/config/$1",
    "^@domain/(.*)$": "<rootDir>/../../src/domain/$1",
    "^@shared/(.*)$": "<rootDir>/../../src/shared/$1",
    "^@templating/(.*)$": "<rootDir>/../../src/base/templating/$1"
  },
  "testTimeout": 50000
}
