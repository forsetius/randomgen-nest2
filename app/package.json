{
  "name": "randomgen",
  "version": "0.4.0",
  "description": "CMS for forseti.pl, Random generators for RPGs",
  "keywords": [
    "rpg",
    "random",
    "generators",
    "cms"
  ],
  "author": "Marcin Forseti Paździora",
  "license": "Custom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forsetius/randomgen-nest2.git"
  },
  "private": true,
  "engines": {
    "node": ">=22.16.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "prepare": "cd .. && husky app/.husky",
    "lint": "eslint \"{src,test}/**/*.ts\" --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "build": "npm run build:pre && npm run build:app",
    "build:pre": "tsc --outDir dist src/preBuild.ts && node dist/preBuild.js",
    "build:app": "tsc",
    "start": "nest start",
    "start:prod": "node dist/main",
    "jest": "TS_NODE_PROJECT=tsconfig.jest.json NODE_OPTIONS=\"-r ts-node/register -r tsconfig-paths/register\" jest",
    "test:prebuild": "TS_NODE_PROJECT=tsconfig.jest.json node -r ts-node/register -r tsconfig-paths/register src/preBuild.ts",
    "test:build": "npm run test:prebuild && swc src -d dist-test --source-maps --copy-files",
    "test:unit": "npm run jest -- --config ./test/jest-unit.config.ts",
    "test:e2e:parallel": "npm run jest -- --config ./test/jest-e2e-parallel.config.ts",
    "test:e2e:serial": "npm run jest -- --config ./test/jest-e2e-serial.config.ts",
    "test": "bash bin/test.sh"
  },
  "dependencies": {
    "@forsetius/glitnir-config": "^0.3.0",
    "@forsetius/glitnir-shared": "^0.1.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "akismet-api": "^6.0.0",
    "axios": "^1.13.2",
    "bootstrap-icons": "^1.13.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "html-minifier-next": "^4.6.1",
    "luxon": "^3.7.2",
    "marked": "^15.0.12",
    "nodemailer": "^7.0.11",
    "nunjucks": "^3.2.4",
    "reflect-metadata": "0.1.14",
    "rxjs": "^7.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.3",
    "@swc/jest": "^0.2.39",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.18.12",
    "@types/nodemailer": "^7.0.4",
    "@types/nunjucks": "^3.2.6",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "eslint --report-unused-disable-directives --max-warnings 0",
      "prettier --ignore-unknown --write"
    ]
  }
}
