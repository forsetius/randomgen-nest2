{
  "name": "randomgen",
  "version": "0.5.0",
  "description": "Random generators for RPGs",
  "keywords": [
    "rpg",
    "random",
    "generators"
  ],
  "author": "Marcin Forseti Paździora",
  "license": "Custom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forsetius/randomgen-nest2.git"
  },
  "private": true,
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "main": "dist/main.js",
  "scripts": {
    "prepare": "command -v husky >/dev/null 2>&1 && (cd .. && husky app/.husky) || true",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "build": "node ./scripts/clean-build.cjs && tsc -p tsconfig.build.json",
    "start": "nest start",
    "start:prod": "node --enable-source-maps dist/main",
    "jest": "NODE_OPTIONS=\"--enable-source-maps\" jest",
    "test:typecheck": "tsc -p tsconfig.jest.json --noEmit",
    "test:unit": "npm run jest -- --config ./test/jest-unit.config.cjs",
    "test:e2e:parallel": "npm run jest -- --config ./test/jest-e2e-parallel.config.cjs",
    "test:e2e:serial": "npm run jest -- --config ./test/jest-e2e-serial.config.cjs",
    "test": "tsx scripts/test.ts",
    "pre-push": "node --import tsx ./scripts/pre-push.ts"
  },
  "dependencies": {
    "@forsetius/glitnir-cms-md": "^0.6.1",
    "@forsetius/glitnir-config": "^0.7.0",
    "@forsetius/glitnir-mail": "^0.3.1",
    "@forsetius/glitnir-markdown": "^0.2.0",
    "@forsetius/glitnir-security": "^0.6.1",
    "@forsetius/glitnir-shared": "^0.3.0",
    "@forsetius/glitnir-spamcheck": "^0.6.1",
    "@forsetius/glitnir-templating": "^0.5.1",
    "@forsetius/glitnir-validation": "^0.6.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/throttler": "^6.5.0",
    "luxon": "^3.7.2",
    "reflect-metadata": "0.1.14",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.32",
    "@swc/jest": "^0.2.39",
    "@tsconfig/node24": "^24.0.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "eslint-plugin-zod": "^3.11.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml}": [
      "prettier --ignore-unknown --write"
    ],
    "**/*.{ts,tsx,js,cjs,mjs,json,yml,yaml}": [
      "eslint --no-warn-ignored --report-unused-disable-directives --max-warnings 0"
    ]
  }
}
